# ============================================================================
#  Radar de Atracción de Recursos — Visión Circular ANDI
#  Copia este archivo como  .env  y completa los valores. NO subas .env a git.
# ============================================================================

# ── Búsqueda web ────────────────────────────────────────────────────────────
# Clave del proveedor activo (definido en config.json -> busqueda.proveedor).
# Sirve para Tavily, Exa, Brave, SerpAPI o Google CSE (según el proveedor elegido).
SEARCH_API_KEY=

# Solo si usas Google Custom Search (proveedor "google_cse"): ID del motor (cx).
GOOGLE_CSE_ID=

# ── Claude (análisis y estructuración) ──────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Gmail (borrador o envío del informe) ────────────────────────────────────
# Cuenta de Gmail que crea el borrador / envía. Requiere App Password (ver README).
GMAIL_SENDER_EMAIL=
GMAIL_APP_PASSWORD=
# Destinatarios del equipo (se precargan en el campo "Para" del borrador), separados por coma.
TEAM_EMAILS=correo1@org.co,correo2@org.co

# ── Opcionales: solo si en el futuro migras a Gmail API con OAuth ────────────
# (El modo actual usa App Password + IMAP y NO los necesita.)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REFRESH_TOKEN=
